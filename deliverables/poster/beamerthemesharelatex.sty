% beamerthemesharelatex.sty
\ProvidesPackage{beamerthemesharelatex}

\usepackage{multicol}

\definecolor{primary}{RGB}{160,32,60}
\definecolor{primarylight}{RGB}{210,180,190}
\definecolor{darkgray}{RGB}{50,50,50}
\definecolor{lightbg}{RGB}{248,245,246}

% Remove navigation symbols
\setbeamertemplate{navigation symbols}{}

% Background
\setbeamercolor{background canvas}{bg=white}

% Title page
\setbeamercolor{title}{fg=white}
\setbeamerfont{title}{size=\Large,series=\bfseries}
\setbeamercolor{author}{fg=white}
\setbeamerfont{author}{size=\normalsize}
\setbeamercolor{institute}{fg=white}
\setbeamerfont{institute}{size=\small}

% Headline / title block
\setbeamertemplate{headline}{
  \leavevmode
  \begin{beamercolorbox}[wd=\paperwidth]{headline}
    \begin{tikzpicture}[remember picture]
      \fill[primary] (0,0) rectangle (\paperwidth, 7.8cm);
      \node[anchor=west, text=white, font=\Large\bfseries, text width=0.75\paperwidth, align=left] 
        at (1.5cm, 5.5cm) {\inserttitle};
      \node[anchor=west, text=white!85, font=\normalsize] 
        at (1.5cm, 3.5cm) {\insertauthor};
      \node[anchor=west, text=white!70, font=\small] 
        at (1.5cm, 2.5cm) {\insertinstitute};
      \node[anchor=east, text=white, font=\small] 
        at (\paperwidth-1.5cm, 2.5cm) {\insertdate};
    \end{tikzpicture}
  \end{beamercolorbox}
  \vskip0.15cm
}

% Section headings style
\setbeamertemplate{section in head/foot}{}
\setbeamercolor{section title}{fg=primary}

% Footline
\setbeamertemplate{footline}{
  \begin{beamercolorbox}[wd=\paperwidth, ht=1.5cm]{footline}
    \begin{tikzpicture}
      \fill[primary] (0,0) rectangle (\paperwidth, 1.5cm);
      \node[anchor=center, text=white, font=\small] at (0.5\paperwidth, 0.75cm) 
        {Deep RL for Snake -- Kapotos, Jamal, Martini -- CentraleSup\'elec 2026};
    \end{tikzpicture}
  \end{beamercolorbox}
}

% Block style
\setbeamercolor{block title}{fg=white, bg=primary}
\setbeamercolor{block body}{fg=darkgray, bg=lightbg}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}

\setbeamertemplate{block begin}{%
  \vskip0.25cm
  \begin{beamercolorbox}[wd=\linewidth, rounded=true, shadow=false,
      leftskip=8pt, rightskip=8pt, sep=3pt]{block title}%
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}%
  \nointerlineskip
  \begin{beamercolorbox}[wd=\linewidth, rounded=true, shadow=false,
      leftskip=8pt, rightskip=8pt, sep=5pt, vmode]{block body}%
    \usebeamerfont{block body}%
}
\setbeamertemplate{block end}{%
  \end{beamercolorbox}
  \vskip0.2cm
}

% Alert block
\setbeamercolor{block title alerted}{fg=white, bg=primary!85!black}
\setbeamercolor{block body alerted}{fg=darkgray, bg=primary!8}

\setbeamertemplate{block alerted begin}{%
  \vskip0.2cm
  \begin{beamercolorbox}[wd=\linewidth, rounded=true, shadow=false,
      leftskip=8pt, rightskip=8pt, sep=4pt]{block title alerted}%
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}%
  \nointerlineskip
  \begin{beamercolorbox}[wd=\linewidth, rounded=true, shadow=false,
      leftskip=8pt, rightskip=8pt, sep=6pt, vmode]{block body alerted}%
    \usebeamerfont{block body}%
}
\setbeamertemplate{block alerted end}{%
  \end{beamercolorbox}
  \vskip0.15cm
}

\mode<all>
